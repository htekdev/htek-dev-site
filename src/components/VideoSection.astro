---
import VideoCard from './VideoCard.astro';

interface Video {
  videoId: string;
  title: string;
  thumbnail: string;
  publishedAt: string;
  stats: { viewCount: number; likeCount: number };
  isNew: boolean;
  isTrending: boolean;
  relatedArticle?: string | null;
  duration: string;
  durationSeconds: number;
  lengthCategory: string;
}

interface Props {
  id: string;
  title: string;
  description: string;
  icon: string;
  videos: Video[];
}

const { id, title, description, icon, videos } = Astro.props;
---

<section data-topic={id} class="topic-section fade-in">
  <div class="flex items-center gap-3 mb-2">
    <span class="text-2xl">{icon}</span>
    <h2 class="text-xl font-heading font-bold text-text-primary">{title}</h2>
    <span class="text-xs text-text-muted font-mono bg-bg-overlay px-2 py-0.5 rounded-full section-count">
      {videos.length} videos
    </span>
  </div>
  <p class="text-text-muted text-sm mb-6">{description}</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {videos.map((video) => (
      <div class="video-card-wrapper" data-length={video.lengthCategory}>
        <VideoCard
          videoId={video.videoId}
          title={video.title}
          thumbnail={video.thumbnail}
          publishedAt={video.publishedAt}
          viewCount={video.stats.viewCount}
          likeCount={video.stats.likeCount}
          isNew={video.isNew}
          isTrending={video.isTrending}
          relatedArticle={video.relatedArticle}
          duration={video.duration}
          durationSeconds={video.durationSeconds}
        />
      </div>
    ))}
  </div>
</section>
