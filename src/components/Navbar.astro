---
const navLinks = [
  { label: 'About', href: '/#about' },
  { label: 'Writing', href: '/#writing' },
  { label: 'Connect', href: '/#connect' },
  { label: 'Articles', href: '/articles' },
];
---

<nav aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 bg-bg-void/80 backdrop-blur-xl border-b border-border-muted">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-mono text-sm font-medium text-text-primary hover:text-accent-cyan transition-colors">
      htek.dev
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center space-x-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-text-muted hover:text-text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/videos"
        class="videos-link text-sm font-semibold transition-all"
      >
        Videos
      </a>
      <a
        href="/agentic-devops"
        class="agentic-btn text-sm font-semibold transition-all"
      >
        Agentic DevOps
      </a>
      <a
        href="/consulting"
        class="consulting-link text-sm font-semibold transition-all"
      >
        Consulting
      </a>
    </div>

    <!-- Mobile Hamburger Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text-muted hover:text-text-primary transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-bg-void/95 backdrop-blur-xl z-50 hidden flex-col items-center justify-center">
  <!-- Close Button -->
  <button
    id="mobile-menu-close"
    class="absolute top-4 right-6 text-text-muted hover:text-text-primary transition-colors"
    aria-label="Close menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile Links -->
  <nav class="flex flex-col items-center space-y-6">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link text-2xl font-heading font-semibold text-text-muted hover:text-text-primary transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/videos"
      class="mobile-nav-link videos-link text-2xl font-heading font-semibold transition-all"
    >
      Videos
    </a>
    <a
      href="/agentic-devops"
      class="mobile-nav-link agentic-btn text-2xl font-heading font-semibold transition-all"
    >
      Agentic DevOps
    </a>
    <a
      href="/consulting"
      class="mobile-nav-link consulting-link text-2xl font-heading font-semibold transition-all"
    >
      Consulting
    </a>
  </nav>
</div>

<script>
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    mobileMenu?.classList.add('flex');
    document.body.style.overflow = 'hidden';
    openBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('flex');
    document.body.style.overflow = '';
    openBtn?.setAttribute('aria-expanded', 'false');
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close when a mobile link is clicked
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .videos-link {
    background: linear-gradient(to right, #FF4444, #FF8800);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .videos-link:hover {
    background: linear-gradient(to right, #FF6666, #FFAA33);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .agentic-btn {
    position: relative;
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    text-decoration: none;
    background: linear-gradient(to right, #34d399, #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .agentic-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    padding: 1px;
    background: linear-gradient(to right, #34d399, #22d3ee);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .agentic-btn:hover::before {
    opacity: 1;
  }

  .agentic-btn:hover {
    background: linear-gradient(to right, #6ee7b7, #67e8f9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .consulting-link {
    background: linear-gradient(to right, #00E5FF, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .consulting-link:hover {
    background: linear-gradient(to right, #33EBFF, #8B5CF6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
