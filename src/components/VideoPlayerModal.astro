---
// Theater-mode video player modal with facade pattern.
// Purely structural HTML — all interactivity lives in videos.astro script.
---

<div
  id="video-modal"
  class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200"
  role="dialog"
  aria-modal="true"
  aria-label="Video player"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/85 backdrop-blur-sm"></div>

  <!-- Close button -->
  <button
    id="modal-close"
    class="absolute top-3 right-3 sm:top-5 sm:right-5 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-bg-surface/80 border border-border-muted text-text-muted hover:text-text-primary hover:border-accent-cyan/50 transition-colors"
    aria-label="Close player"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Content wrapper -->
  <div class="modal-content relative w-full max-w-4xl mx-4 transform scale-95 transition-transform duration-200">
    <!-- Player area with navigation arrows -->
    <div class="relative group/player">
      <!-- Previous video -->
      <button
        id="modal-prev"
        class="absolute left-2 sm:-left-14 top-1/2 -translate-y-1/2 z-10 w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center rounded-full bg-bg-surface/80 border border-border-muted text-text-muted hover:text-accent-cyan hover:border-accent-cyan/50 transition-all opacity-0 group-hover/player:opacity-100 sm:opacity-70 sm:hover:opacity-100"
        aria-label="Previous video"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Player -->
      <div id="modal-player" class="aspect-video bg-black rounded-xl overflow-hidden relative shadow-2xl shadow-black/50">
        <!-- Facade: thumbnail + play button (shown until user clicks play) -->
        <div id="modal-facade" class="absolute inset-0 cursor-pointer">
          <img id="modal-thumbnail" class="w-full h-full object-cover" alt="" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent flex items-center justify-center transition-colors hover:via-black/30">
            <div class="w-16 h-16 sm:w-20 sm:h-20 flex items-center justify-center rounded-full bg-accent-cyan/90 text-bg-void shadow-lg shadow-accent-cyan/30 transition-transform hover:scale-110 active:scale-95">
              <svg class="w-8 h-8 sm:w-10 sm:h-10 ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
        </div>
        <!-- Iframe container (populated by JS when user clicks play) -->
        <div id="modal-iframe-container" class="absolute inset-0 hidden"></div>
      </div>

      <!-- Next video -->
      <button
        id="modal-next"
        class="absolute right-2 sm:-right-14 top-1/2 -translate-y-1/2 z-10 w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center rounded-full bg-bg-surface/80 border border-border-muted text-text-muted hover:text-accent-cyan hover:border-accent-cyan/50 transition-all opacity-0 group-hover/player:opacity-100 sm:opacity-70 sm:hover:opacity-100"
        aria-label="Next video"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Info panel -->
    <div class="mt-3 p-4 bg-bg-surface/90 border border-border-muted rounded-xl backdrop-blur-sm">
      <h3 id="modal-title" class="text-base sm:text-lg font-heading font-bold text-text-primary leading-snug"></h3>
      <div class="flex items-center gap-2 sm:gap-3 mt-2 text-xs sm:text-sm text-text-muted flex-wrap">
        <span id="modal-date"></span>
        <span class="modal-sep text-border-default">&middot;</span>
        <span id="modal-views"></span>
        <span class="modal-sep text-border-default">&middot;</span>
        <span id="modal-duration"></span>
        <span class="modal-sep text-border-default">&middot;</span>
        <span id="modal-counter" class="text-accent-cyan font-mono text-xs"></span>
      </div>
      <div class="flex items-center gap-4 mt-3 flex-wrap">
        <a
          id="modal-yt-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-xs sm:text-sm text-accent-cyan hover:underline font-medium"
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Watch on YouTube
        </a>
        <a
          id="modal-article-link"
          href="#"
          class="hidden inline-flex items-center gap-1 text-xs sm:text-sm text-accent-violet hover:underline font-medium"
        >
          📝 Related article →
        </a>
      </div>
    </div>
  </div>
</div>

<style is:global>
  #video-modal.open {
    opacity: 1;
    pointer-events: auto;
  }
  #video-modal.open .modal-content {
    transform: scale(1);
  }
</style>
