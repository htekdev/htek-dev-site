---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

const sorted = (await getCollection('articles'))
  .filter(a => !a.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const now = new Date();
function getRelativeLabel(date: Date): string {
  const diffMs = now.valueOf() - date.valueOf();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays <= 7)  return 'This week';
  if (diffDays <= 14) return 'Last week';
  if (diffDays <= 30) return 'This month';
  return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

// Show up to 5 most recent, grouped by relative period
const RECENT_LIMIT = 5;
const articles = sorted.slice(0, RECENT_LIMIT);

// Determine the freshness label for the latest article
const latestLabel = articles.length > 0 ? getRelativeLabel(articles[0].data.pubDate) : '';
---

<section id="writing" class="fade-in py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-baseline gap-4 flex-wrap">
      <h2 class="text-3xl md:text-4xl font-heading font-bold gradient-text">Writing</h2>
      {latestLabel && (
        <span class="text-sm text-accent-cyan font-mono">
          Latest: {latestLabel}
        </span>
      )}
    </div>
    <p class="text-text-muted mt-2">Thoughts on AI, development, and the future of software</p>

    {articles.length > 0 ? (
      <>
        <div class="space-y-6 mt-10">
          {articles.map(article => (
            <div class="relative">
              <span class="absolute -top-2.5 right-0 text-xs text-text-muted font-mono">
                {getRelativeLabel(article.data.pubDate)}
              </span>
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                pubDate={article.data.pubDate}
                slug={article.id}
                tags={article.data.tags}
              />
            </div>
          ))}
        </div>
        <a href="/articles" class="text-accent-cyan text-sm hover:underline mt-8 inline-block">
          View all articles →
        </a>
      </>
    ) : (
      <p class="text-text-muted italic mt-12">Articles coming soon.</p>
    )}
  </div>
</section>
