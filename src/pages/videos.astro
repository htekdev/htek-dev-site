---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import VideoPlayerModal from '../components/VideoPlayerModal.astro';
import VideoHero from '../components/VideoHero.astro';
import VideoSection from '../components/VideoSection.astro';
import videoData from '../data/youtube-videos.json';

const allVideos = videoData.topics.flatMap(t => t.videos);
const shortCount = allVideos.filter(v => v.durationSeconds < 60).length;
const standardCount = allVideos.filter(v => v.durationSeconds >= 60 && v.durationSeconds < 600).length;
const deepDiveCount = allVideos.filter(v => v.durationSeconds >= 600).length;
---

<BaseLayout
  title="Videos — htek.dev"
  description="YouTube videos on agentic DevOps, AI development, testing, and software engineering by Hector Flores."
>
  <Navbar />
  <main id="main-content">
    <VideoHero
      totalVideos={videoData.stats.totalVideos}
      totalViews={videoData.stats.totalViews}
      subscribers={videoData.stats.subscribers}
      lastUpdated={videoData.lastUpdated}
    />

    <div class="max-w-6xl mx-auto px-6 py-16">
      <!-- Filter controls -->
      <div class="space-y-4 mb-12">
        <!-- Topic filter -->
        <div class="flex items-center gap-2 flex-wrap" id="topic-filters" aria-label="Filter by topic">
          <button
            data-topic="all"
            class="filter-btn topic-btn text-xs px-3 py-1.5 rounded-full border border-accent-cyan bg-accent-cyan/10 text-accent-cyan transition-colors"
            aria-pressed="true"
          >All Topics</button>
          {videoData.topics.map(topic => (
            <button
              data-topic={topic.id}
              class="filter-btn topic-btn text-xs px-3 py-1.5 rounded-full border border-border-muted text-text-muted hover:border-accent-cyan/50 hover:text-accent-cyan transition-colors"
              aria-pressed="false"
            >
              {topic.icon} {topic.title}
            </button>
          ))}
        </div>

        <!-- Duration filter — compact segmented control -->
        <div class="flex items-center gap-3" id="duration-filters" aria-label="Filter by duration">
          <span class="text-[11px] text-text-muted font-mono uppercase tracking-wider">Duration</span>
          <div class="flex items-center gap-1 bg-bg-surface border border-border-muted rounded-lg p-0.5">
            <button data-duration="all" class="dur-btn text-xs px-3 py-1 rounded-md transition-all bg-white/10 text-text-primary font-semibold" aria-pressed="true">
              All
            </button>
            <button data-duration="short" class="dur-btn text-xs px-3 py-1 rounded-md transition-all text-text-muted hover:text-text-primary" aria-pressed="false">
              ⚡ Shorts <span class="dur-count text-text-muted/50 ml-0.5" data-dur="short">{shortCount}</span>
            </button>
            <button data-duration="standard" class="dur-btn text-xs px-3 py-1 rounded-md transition-all text-text-muted hover:text-text-primary" aria-pressed="false">
              🎬 Standard <span class="dur-count text-text-muted/50 ml-0.5" data-dur="standard">{standardCount}</span>
            </button>
            <button data-duration="deep-dive" class="dur-btn text-xs px-3 py-1 rounded-md transition-all text-text-muted hover:text-text-primary" aria-pressed="false">
              🎓 Deep Dives <span class="dur-count text-text-muted/50 ml-0.5" data-dur="deep-dive">{deepDiveCount}</span>
            </button>
          </div>
        </div>
      </div>

      <!-- No results message -->
      <div id="no-results" class="hidden text-center py-16">
        <p class="text-text-muted text-lg">No videos match this filter combination.</p>
        <button id="clear-filters" class="mt-4 text-sm text-accent-cyan hover:underline">Clear all filters</button>
      </div>

      <!-- Topic sections -->
      <div id="topics-root" class="space-y-16">
        {videoData.topics.map(topic => (
          <VideoSection
            id={topic.id}
            title={topic.title}
            description={topic.description}
            icon={topic.icon}
            videos={topic.videos}
          />
        ))}
      </div>
    </div>
  </main>
  <Footer />
  <VideoPlayerModal />
</BaseLayout>

<script>
  let activeTopic = 'all';
  let activeDuration = 'all';

  function applyFilters() {
    let totalVisible = 0;
    const durCounts: Record<string, number> = { 'short': 0, 'standard': 0, 'deep-dive': 0 };

    document.querySelectorAll<HTMLElement>('#topics-root .topic-section').forEach(section => {
      const topicId = section.dataset.topic;
      const topicMatch = activeTopic === 'all' || topicId === activeTopic;

      if (!topicMatch) {
        section.style.display = 'none';
        return;
      }

      let sectionVisible = 0;
      section.querySelectorAll<HTMLElement>('.video-card-wrapper').forEach(card => {
        const lengthCat = card.dataset.length ?? '';
        const durationMatch = activeDuration === 'all' || lengthCat === activeDuration;
        card.style.display = durationMatch ? '' : 'none';
        if (durationMatch) sectionVisible++;
        // Count all cards in matching topics for duration badge updates
        if (lengthCat) durCounts[lengthCat] = (durCounts[lengthCat] || 0) + 1;
      });

      // Update section count badge
      const countEl = section.querySelector('.section-count');
      if (countEl && activeDuration !== 'all') {
        const total = section.querySelectorAll('.video-card-wrapper').length;
        countEl.textContent = `${sectionVisible}/${total} videos`;
      } else if (countEl) {
        const total = section.querySelectorAll('.video-card-wrapper').length;
        countEl.textContent = `${total} videos`;
      }

      section.style.display = sectionVisible > 0 ? '' : 'none';
      totalVisible += sectionVisible;
    });

    // Update duration filter counts to reflect the active topic
    document.querySelectorAll<HTMLElement>('.dur-count').forEach(el => {
      const dur = el.dataset.dur ?? '';
      el.textContent = String(durCounts[dur] || 0);
    });

    const noResults = document.getElementById('no-results');
    noResults?.classList.toggle('hidden', totalVisible > 0);
  }

  // Topic filter
  const topicFilterBar = document.getElementById('topic-filters');
  topicFilterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-topic]');
    if (!btn) return;
    activeTopic = btn.dataset.topic ?? 'all';

    topicFilterBar.querySelectorAll<HTMLButtonElement>('.topic-btn').forEach(b => {
      const selected = b.dataset.topic === activeTopic;
      b.classList.toggle('border-accent-cyan', selected);
      b.classList.toggle('bg-accent-cyan/10', selected);
      b.classList.toggle('text-accent-cyan', selected);
      b.classList.toggle('border-border-muted', !selected);
      b.classList.toggle('text-text-muted', !selected);
      b.setAttribute('aria-pressed', String(selected));
    });

    applyFilters();
  });

  // Duration filter
  const durationFilterBar = document.getElementById('duration-filters');
  durationFilterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-duration]');
    if (!btn) return;
    activeDuration = btn.dataset.duration ?? 'all';

    durationFilterBar.querySelectorAll<HTMLButtonElement>('.dur-btn').forEach(b => {
      const selected = b.dataset.duration === activeDuration;
      b.classList.toggle('bg-white/10', selected);
      b.classList.toggle('text-text-primary', selected);
      b.classList.toggle('font-semibold', selected);
      b.classList.toggle('text-text-muted', !selected);
      b.setAttribute('aria-pressed', String(selected));
    });

    applyFilters();
  });

  // Clear filters
  document.getElementById('clear-filters')?.addEventListener('click', () => {
    activeTopic = 'all';
    activeDuration = 'all';

    topicFilterBar?.querySelectorAll<HTMLButtonElement>('.topic-btn').forEach(b => {
      const selected = b.dataset.topic === 'all';
      b.classList.toggle('border-accent-cyan', selected);
      b.classList.toggle('bg-accent-cyan/10', selected);
      b.classList.toggle('text-accent-cyan', selected);
      b.classList.toggle('border-border-muted', !selected);
      b.classList.toggle('text-text-muted', !selected);
      b.setAttribute('aria-pressed', String(selected));
    });

    durationFilterBar?.querySelectorAll<HTMLButtonElement>('.dur-btn').forEach(b => {
      const selected = b.dataset.duration === 'all';
      b.classList.toggle('bg-white/10', selected);
      b.classList.toggle('text-text-primary', selected);
      b.classList.toggle('font-semibold', selected);
      b.classList.toggle('text-text-muted', !selected);
      b.setAttribute('aria-pressed', String(selected));
    });

    applyFilters();
  });

  // ================================================================
  // VIDEO PLAYER MODAL
  // ================================================================

  const modal = document.getElementById('video-modal')!;
  const modalBackdrop = document.getElementById('modal-backdrop')!;
  const modalClose = document.getElementById('modal-close')!;
  const modalPrev = document.getElementById('modal-prev')!;
  const modalNext = document.getElementById('modal-next')!;
  const modalFacade = document.getElementById('modal-facade')!;
  const modalThumbnail = document.getElementById('modal-thumbnail') as HTMLImageElement;
  const modalIframeContainer = document.getElementById('modal-iframe-container')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalDate = document.getElementById('modal-date')!;
  const modalViews = document.getElementById('modal-views')!;
  const modalDuration = document.getElementById('modal-duration')!;
  const modalCounter = document.getElementById('modal-counter')!;
  const modalYtLink = document.getElementById('modal-yt-link') as HTMLAnchorElement;
  const modalArticleLink = document.getElementById('modal-article-link') as HTMLAnchorElement;

  let currentVideoIndex = 0;
  let filteredVideos: HTMLButtonElement[] = [];
  let triggerButton: HTMLButtonElement | null = null;

  function getFilteredVideos(): HTMLButtonElement[] {
    const visible: HTMLButtonElement[] = [];
    document.querySelectorAll<HTMLElement>('#topics-root .video-card-wrapper').forEach(card => {
      if (card.style.display === 'none') return;
      const section = card.closest('.topic-section') as HTMLElement | null;
      if (section && section.style.display === 'none') return;
      const btn = card.querySelector<HTMLButtonElement>('button[data-video-id]');
      if (btn) visible.push(btn);
    });
    return visible;
  }

  function populateModal(btn: HTMLButtonElement) {
    const videoId = btn.dataset.videoId ?? '';
    const title = btn.dataset.title ?? '';
    const views = btn.dataset.views ?? '';
    const date = btn.dataset.date ?? '';
    const duration = btn.dataset.duration ?? '';
    const relatedArticle = btn.dataset.relatedArticle ?? '';

    modalTitle.textContent = title;
    modalDate.textContent = date;
    modalViews.textContent = `${views} views`;
    modalDuration.textContent = duration;
    modalCounter.textContent = `${currentVideoIndex + 1} of ${filteredVideos.length}`;

    // Use HD thumbnail for the modal facade, fall back to card thumbnail
    const hdThumb = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
    const fallbackThumb = btn.dataset.thumbnail ?? '';
    modalThumbnail.onerror = () => { modalThumbnail.onerror = null; modalThumbnail.src = fallbackThumb; };
    modalThumbnail.src = hdThumb;
    modalThumbnail.alt = title;

    modalYtLink.href = `https://www.youtube.com/watch?v=${videoId}`;

    if (relatedArticle) {
      modalArticleLink.href = relatedArticle;
      modalArticleLink.classList.remove('hidden');
    } else {
      modalArticleLink.classList.add('hidden');
    }

    // Reset to facade (remove any playing iframe)
    modalFacade.classList.remove('hidden');
    modalIframeContainer.classList.add('hidden');
    modalIframeContainer.innerHTML = '';

    // Update URL hash for deep linking
    history.replaceState(null, '', `#video=${videoId}`);

    // Show/hide nav arrows
    const hasMultiple = filteredVideos.length > 1;
    modalPrev.style.display = hasMultiple ? '' : 'none';
    modalNext.style.display = hasMultiple ? '' : 'none';
  }

  function playVideo() {
    const btn = filteredVideos[currentVideoIndex];
    if (!btn) return;
    const videoId = btn.dataset.videoId ?? '';
    const title = btn.dataset.title ?? '';

    modalFacade.classList.add('hidden');
    modalIframeContainer.classList.remove('hidden');
    modalIframeContainer.innerHTML = `<iframe
      src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1"
      class="w-full h-full"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      title="${title.replace(/"/g, '&quot;')}"
    ></iframe>`;
  }

  function openModal(btn: HTMLButtonElement) {
    filteredVideos = getFilteredVideos();
    currentVideoIndex = filteredVideos.indexOf(btn);
    if (currentVideoIndex === -1) currentVideoIndex = 0;
    triggerButton = btn;

    populateModal(btn);
    playVideo();

    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    modalClose.focus();
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';

    // Stop any playing video
    modalIframeContainer.innerHTML = '';
    modalIframeContainer.classList.add('hidden');
    modalFacade.classList.remove('hidden');

    // Clear URL hash
    history.replaceState(null, '', window.location.pathname + window.location.search);

    // Return focus to the card that opened the modal
    triggerButton?.focus();
    triggerButton = null;
  }

  function navigateVideo(direction: number) {
    if (filteredVideos.length <= 1) return;
    // Rebuild list in case filters changed while modal was open
    filteredVideos = getFilteredVideos();
    if (filteredVideos.length === 0) { closeModal(); return; }
    currentVideoIndex = (currentVideoIndex + direction + filteredVideos.length) % filteredVideos.length;
    populateModal(filteredVideos[currentVideoIndex]);
    playVideo();
  }

  // Card click → open modal (event delegation on the video grid)
  document.getElementById('topics-root')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button[data-video-id]');
    if (btn) openModal(btn);
  });

  // Facade play button → load iframe
  modalFacade.addEventListener('click', playVideo);

  // Close triggers
  modalClose.addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', closeModal);

  // Prev / Next navigation
  modalPrev.addEventListener('click', () => navigateVideo(-1));
  modalNext.addEventListener('click', () => navigateVideo(1));

  // Keyboard shortcuts (only when modal is open)
  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('open')) return;
    switch (e.key) {
      case 'Escape':
        closeModal();
        break;
      case 'ArrowLeft':
        e.preventDefault();
        navigateVideo(-1);
        break;
      case 'ArrowRight':
        e.preventDefault();
        navigateVideo(1);
        break;
    }
  });

  // Deep link: open modal if URL has #video=VIDEO_ID
  (function checkDeepLink() {
    const hash = window.location.hash;
    const match = hash.match(/^#video=(.+)$/);
    if (!match) return;
    const videoId = match[1];
    const btn = document.querySelector<HTMLButtonElement>(`button[data-video-id="${videoId.replace(/"/g, '\\"')}"]`);
    if (btn) openModal(btn);
  })();
</script>
