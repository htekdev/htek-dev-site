          class={`dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-accent-green w-6' : 'bg-white/20 hover:bg-white/40'}`}
          data-dot={i}
          aria-label={`Go to slide ${i + 1}`}
        ></button>
