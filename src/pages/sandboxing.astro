---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const isolationLevels = [
  {
    level: 'L1',
    label: 'Process',
    tech: 'seccomp-bpf, Landlock',
    how: 'Syscall filtering and filesystem restrictions on a single process',
    kernelShared: 'Yes',
    escapeRisk: 'Medium',
    overhead: 'Near-zero',
    os: 'Linux',
    color: '#f87171',
    colorMuted: 'rgba(248,113,113,0.15)',
    colorBorder: 'rgba(248,113,113,0.3)',
    protects: ['Filesystem paths', 'Syscall surface'],
    whenToUse: 'Low-trust local scripts, helper processes, tight latency requirements',
    tradeoff: 'Shared kernel — kernel exploit can escape the sandbox',
  },
  {
    level: 'L2',
    label: 'Namespace',
    tech: 'Bubblewrap, Firejail',
    how: 'Linux namespaces (PID, mount, net, user) wrap a process in isolation',
    kernelShared: 'Yes',
    escapeRisk: 'Low-Medium',
    overhead: 'Near-zero',
    os: 'Linux',
    color: '#fb923c',
    colorMuted: 'rgba(251,146,60,0.15)',
    colorBorder: 'rgba(251,146,60,0.3)',
    protects: ['Filesystem', 'Network', 'Process tree', 'User IDs'],
    whenToUse: 'Local agent execution, dev machines, Linux-native workflows',
    tradeoff: 'Linux-only; still shares kernel with host',
  },
  {
    level: 'L3',
    label: 'Container',
    tech: 'Docker, Podman, Incus',
    how: 'Full container with cgroups, namespaces, and layered filesystem',
    kernelShared: 'Yes',
    escapeRisk: 'Low (CVEs exist)',
    overhead: 'Low',
    os: 'Linux, macOS, Windows',
    color: '#fbbf24',
    colorMuted: 'rgba(251,191,36,0.15)',
    colorBorder: 'rgba(251,191,36,0.3)',
    protects: ['Filesystem', 'Network', 'Process tree', 'Resource limits'],
    whenToUse: 'Cross-platform agent workloads, ephemeral environments, most cloud deployments',
    tradeoff: 'Kernel escape CVEs (runc, containerd history); not true hardware isolation',
  },
  {
    level: 'L4',
    label: 'Userspace Kernel',
    tech: 'gVisor',
    how: 'Intercepts syscalls in userspace, emulates kernel behavior — host kernel never touched',
    kernelShared: 'Partial',
    escapeRisk: 'Low',
    overhead: 'Medium',
    os: 'Linux',
    color: '#34d399',
    colorMuted: 'rgba(52,211,153,0.15)',
    colorBorder: 'rgba(52,211,153,0.3)',
    protects: ['Filesystem', 'Network', 'Syscall surface', 'Host kernel'],
    whenToUse: 'Untrusted code execution in cloud, GKE workloads, moderate performance requirement',
    tradeoff: 'Performance overhead on syscall-heavy workloads; not all syscalls supported',
  },
  {
    level: 'L5',
    label: 'MicroVM',
    tech: 'Firecracker, Cloud Hypervisor',
    how: 'Dedicated kernel per workload via hardware virtualization (KVM)',
    kernelShared: 'No',
    escapeRisk: 'Very Low',
    overhead: 'Medium-High',
    os: 'Linux (KVM)',
    color: '#818cf8',
    colorMuted: 'rgba(129,140,248,0.15)',
    colorBorder: 'rgba(129,140,248,0.3)',
    protects: ['Filesystem', 'Network', 'Kernel', 'Memory isolation'],
    whenToUse: 'Cloud sandboxes (E2B, Fly.io), multi-tenant agent platforms, high-security requirements',
    tradeoff: 'Requires KVM; cold start 100ms–1s; harder local dev',
  },
  {
    level: 'L6',
    label: 'Full VM',
    tech: 'QEMU/KVM, Hyper-V',
    how: 'Complete OS isolation with dedicated hardware abstraction',
    kernelShared: 'No',
    escapeRisk: 'Minimal',
    overhead: 'High',
    os: 'Cross-platform',
    color: '#c084fc',
    colorMuted: 'rgba(192,132,252,0.15)',
    colorBorder: 'rgba(192,132,252,0.3)',
    protects: ['Full OS stack', 'Hardware abstraction', 'Network', 'Storage'],
    whenToUse: 'Maximum security, legacy workloads, compliance-mandated isolation',
    tradeoff: 'High overhead; slow cold start (minutes); operational complexity',
  },
  {
    level: 'L7',
    label: 'Policy Engine',
    tech: 'NVIDIA OpenShell',
    how: 'Combines multiple isolation levels + L7 HTTP inspection per binary/endpoint',
    kernelShared: 'Varies',
    escapeRisk: 'Very Low',
    overhead: 'Medium',
    os: 'Linux (k3s)',
    color: '#22d3ee',
    colorMuted: 'rgba(34,211,238,0.15)',
    colorBorder: 'rgba(34,211,238,0.3)',
    protects: ['Filesystem', 'Network (method+path)', 'Processes', 'API endpoints', 'GPU access'],
    whenToUse: 'Enterprise agent governance, GPU inference, multi-tenant, policy-as-code requirement',
    tradeoff: 'Per-endpoint policy maintenance; k3s cluster required; seconds cold start',
  },
];

const tools = [
  { name: 'Bubblewrap (bwrap)', level: 'L2', os: 'Linux', gpu: false, selfHosted: true, openSource: 'LGPL', coldStart: 'Instant', pricing: 'Free', link: 'https://github.com/containers/bubblewrap' },
  { name: 'Firejail', level: 'L2', os: 'Linux', gpu: false, selfHosted: true, openSource: 'GPL', coldStart: 'Instant', pricing: 'Free', link: 'https://firejail.wordpress.com' },
  { name: 'Docker Sandboxes', level: 'L3', os: 'Lin/Mac/Win', gpu: 'Limited', selfHosted: true, openSource: 'Partial', coldStart: 'Sub-second', pricing: 'Free', link: 'https://www.docker.com' },
  { name: 'Clampdown', level: 'L3', os: 'Linux/macOS', gpu: false, selfHosted: true, openSource: 'Yes', coldStart: 'Fast', pricing: 'Free', link: 'https://github.com/getlocalci/clampdown' },
  { name: 'code-on-incus', level: 'L3', os: 'Linux', gpu: false, selfHosted: true, openSource: 'Yes', coldStart: 'Fast', pricing: 'Free', link: 'https://github.com/anthropics/anthropic-quickstarts/tree/main/computer-use-demo' },
  { name: 'Daytona', level: 'L3', os: 'Cross-platform', gpu: true, selfHosted: true, openSource: 'AGPL', coldStart: '<90ms', pricing: '~$0.08/hr', link: 'https://www.daytona.io' },
  { name: 'BoxLite', level: 'L3+', os: 'Linux/macOS', gpu: false, selfHosted: true, openSource: 'Rust', coldStart: 'Fast', pricing: 'Free', link: 'https://github.com/nicholasgasior/boxlite' },
  { name: 'Sandbox0', level: 'L3', os: 'Linux', gpu: false, selfHosted: true, openSource: 'Go', coldStart: 'Fast', pricing: 'Free', link: 'https://github.com/bluesky-social/sandbox0' },
  { name: 'ContainAI', level: 'L3', os: 'Linux', gpu: false, selfHosted: true, openSource: 'MIT', coldStart: 'Fast', pricing: 'Free', link: 'https://github.com/containai/containai' },
  { name: 'Cagent', level: 'L3+', os: 'Linux', gpu: false, selfHosted: true, openSource: 'Yes', coldStart: 'Fast', pricing: 'Free', link: 'https://github.com/anthropics/cagent' },
  { name: 'Modal', level: 'L4', os: 'Cloud', gpu: 'Best', selfHosted: false, openSource: 'No', coldStart: 'Sub-second', pricing: 'Pay/sec', link: 'https://modal.com' },
  { name: 'Google Agent Sandbox', level: 'L4+', os: 'GKE', gpu: true, selfHosted: false, openSource: 'Yes', coldStart: 'Varies', pricing: 'GKE pricing', link: 'https://github.com/google-deepmind/agent-sandbox' },
  { name: 'k8s-sigs/agent-sandbox', level: 'L4+', os: 'Any K8s', gpu: true, selfHosted: true, openSource: 'Yes', coldStart: 'Varies', pricing: 'Free', link: 'https://github.com/kubernetes-sigs/agent-sandbox' },
  { name: 'E2B', level: 'L5', os: 'Cloud', gpu: false, selfHosted: 'Terraform', openSource: 'Partial', coldStart: '~150ms', pricing: '~$0.08/hr', link: 'https://e2b.dev' },
  { name: 'Fly.io Sprites', level: 'L5', os: 'Cloud', gpu: false, selfHosted: false, openSource: 'No', coldStart: '1–12s', pricing: 'Per-second', link: 'https://fly.io' },
  { name: 'Northflank', level: 'L5', os: 'Cloud', gpu: false, selfHosted: 'BYOC', openSource: 'No', coldStart: 'Fast', pricing: 'Per-second', link: 'https://northflank.com' },
  { name: 'Alibaba OpenSandbox', level: 'L3', os: 'Linux', gpu: false, selfHosted: true, openSource: 'Apache 2.0', coldStart: 'Varies', pricing: 'Free', link: 'https://github.com/alibaba/open-sandbox' },
  { name: 'Microsandbox', level: 'L5', os: 'Linux', gpu: false, selfHosted: true, openSource: 'Apache 2.0', coldStart: 'Varies', pricing: 'Free', link: 'https://github.com/microsandbox/microsandbox' },
  { name: 'NVIDIA OpenShell', level: 'L7', os: 'Linux (k3s)', gpu: true, selfHosted: true, openSource: 'Apache 2.0', coldStart: 'Seconds', pricing: 'Free', link: '/articles/nvidia-openshell-sandbox-ai-agents' },
];

const threatModels = [
  { emoji: '🏠', threat: 'Local filesystem access', defense: 'Agent reads ~/.ssh, .env, credentials', level: 'L2', tools: 'Bubblewrap, Firejail' },
  { emoji: '🌐', threat: 'Network exfiltration', defense: 'Agent sends data to unauthorized endpoints', level: 'L3–L7', tools: 'Docker (port-level), OpenShell (method-level)' },
  { emoji: '💣', threat: 'Destructive commands', defense: 'Agent runs rm -rf, drops tables', level: 'L2–L3', tools: 'Bubblewrap (read-only mounts), Docker' },
  { emoji: '🔑', threat: 'Privilege escalation', defense: 'Agent gains root, installs packages', level: 'L1–L3', tools: 'seccomp, containers' },
  { emoji: '🧬', threat: 'Kernel exploit', defense: 'Agent escapes via kernel vulnerability', level: 'L5–L6', tools: 'Firecracker, QEMU (separate kernel)' },
  { emoji: '📡', threat: 'API abuse', defense: 'Agent calls wrong endpoints or methods', level: 'L7', tools: 'OpenShell (HTTP path + method inspection)' },
  { emoji: '🔄', threat: 'State persistence', defense: 'Agent needs to survive restarts', level: 'L3+', tools: 'BoxLite (snapshots), OpenShell, Sandbox0' },
  { emoji: '⚡', threat: 'Latency-sensitive workflows', defense: 'Interactive agent, can\'t wait for boot', level: 'L1–L2', tools: 'seccomp (zero), Bubblewrap (instant)' },
  { emoji: '🎮', threat: 'GPU inference', defense: 'Agent needs local model inference', level: 'L5–L7', tools: 'OpenShell (DGX/RTX), Modal, K8s' },
];

const considerations = [
  { icon: '⚖️', title: 'Performance vs Security', body: 'L2 is instant but shares the kernel. L5 is isolated but adds cold start overhead. Pick based on your actual threat model — most agents don\'t need MicroVM protection.' },
  { icon: '🖥️', title: 'OS Portability', body: 'Bubblewrap, Firejail, and Landlock are Linux-only. If your agents run on macOS or Windows dev machines, containers are your minimum viable sandbox.' },
  { icon: '📋', title: 'Policy Maintenance', body: 'L7 policy engines require per-endpoint maintenance. Is your team prepared to define and update network policies per agent binary? It\'s powerful but carries operational cost.' },
  { icon: '🚪', title: 'Escape Surface', body: 'Containers share the kernel — container escape CVEs (runc, containerd) have a documented history. MicroVMs isolate at hardware. Know what you\'re trusting.' },
  { icon: '🔍', title: 'Debugging Complexity', body: 'More isolation means harder debugging. Audit logs help but add overhead. Plan your observability strategy before locking down the sandbox.' },
  { icon: '🎮', title: 'GPU Passthrough', body: 'Most lightweight sandboxes can\'t pass GPUs to containerized workloads. If your agent needs local inference, plan for L5+ or a managed GPU sandbox like Modal or OpenShell.' },
  { icon: '💾', title: 'Statefulness', body: 'Ephemeral sandboxes (E2B, Firecracker) are great for short-lived tasks. Persistent agents (long-running sessions, file editing) need snapshot support or persistent volumes.' },
  { icon: '🕐', title: 'Cold Start', body: 'Instant (bwrap) → sub-second (Docker) → ~150ms (E2B) → 1–12s (Fly.io Sprites) → minutes (full VM). Match cold start budget to the UX you need.' },
  { icon: '🌐', title: 'DNS in Cluster Sandboxes', body: 'K8s-based sandboxes can have DNS issues in child namespaces. Test your agent\'s DNS resolution behavior early — silent DNS failures are a common gotcha.' },
];

const stackLayers = [
  { layer: '0: Sandbox', what: 'Execution boundary', where: 'This page', here: true },
  { layer: '1: Instructions', what: 'Context engineering', where: 'Agent-Proof Architecture', link: '/articles/agent-proof-architecture-agentic-devops' },
  { layer: '2: Hooks', what: 'Tool-call interception', where: 'Copilot CLI Hooks', link: '/articles/agent-hooks-controlling-ai-codebase' },
  { layer: '3: Gates', what: 'CI/CD validation', where: 'Agentic Workflows', link: '/articles/github-agentic-workflows-hands-on-guide' },
];
---

<BaseLayout
  title="Agent Sandboxing — htek.dev"
  description="The definitive guide to agent sandboxing: every isolation level, every tool, and how to choose what fits your threat model."
>
  <Navbar />
  <main id="main-content">

    <!-- Hero -->
    <section class="relative min-h-[85vh] flex items-center bg-bg-void overflow-hidden">
      <!-- Background effects -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-accent-cyan/8 rounded-full blur-[120px]"></div>
        <div class="absolute top-1/3 left-1/4 w-[300px] h-[300px] bg-accent-violet/5 rounded-full blur-[80px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[250px] h-[250px] bg-accent-green/5 rounded-full blur-[80px]"></div>
      </div>
      <!-- Grid overlay -->
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(34,211,238,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(34,211,238,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-5xl mx-auto px-6 pt-32 pb-20 text-center">
        <span class="inline-block font-mono text-accent-cyan text-sm tracking-wider mb-6 opacity-80">// agent-sandboxing</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-text-primary mb-8 leading-tight">
          Your Agent Has Access.
          <span class="block mt-2">
            <span class="sandbox-gradient">The Question Is: How Much?</span>
          </span>
        </h1>
        <p class="text-lg md:text-xl text-text-secondary max-w-3xl mx-auto mb-12 leading-relaxed">
          Agent sandboxing isn't one thing — it's a spectrum from lightweight process isolation to full policy-governed runtimes.
          This page maps every level, every tool, and helps you choose what fits your threat model.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 flex-wrap">
          <a href="#spectrum" class="inline-flex items-center gap-2 bg-accent-cyan/15 border border-accent-cyan/30 text-accent-cyan font-semibold px-8 py-3 rounded-lg hover:bg-accent-cyan/25 transition-all">
            See the Levels
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
          </a>
          <a href="#tools" class="inline-flex items-center gap-2 bg-white/5 border border-white/10 text-text-secondary hover:text-text-primary hover:border-accent-cyan/30 font-medium px-8 py-3 rounded-lg transition-all">
            Compare Tools ↓
          </a>
          <a href="#threat-model" class="inline-flex items-center gap-2 text-text-muted hover:text-text-primary font-medium px-8 py-3 rounded-lg transition-colors">
            Choose by Threat Model →
          </a>
        </div>
      </div>
    </section>

    <!-- Section 1: The Spectrum -->
    <section id="spectrum" class="fade-in py-24 md:py-32 bg-bg-surface relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] bg-accent-cyan/5 rounded-full blur-[100px]"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-6">
        <span class="inline-block font-mono text-accent-cyan text-sm tracking-wider mb-4">// the big picture</span>
        <h2 class="text-3xl md:text-5xl font-heading font-bold text-text-primary mb-6">The Isolation Spectrum</h2>
        <p class="text-text-secondary text-lg max-w-3xl mb-16">
          Before diving into the full taxonomy, here's the landscape. Every sandbox sits somewhere on this spectrum — the tradeoff is always isolation strength vs. overhead.
        </p>

        <!-- Spectrum SVG -->
        <div class="overflow-x-auto mb-16">
          <svg viewBox="0 0 900 220" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[900px] mx-auto">
            <defs>
              <linearGradient id="spectrum-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#f87171" stop-opacity="0.6"/>
                <stop offset="25%" stop-color="#fb923c" stop-opacity="0.6"/>
                <stop offset="50%" stop-color="#fbbf24" stop-opacity="0.6"/>
                <stop offset="70%" stop-color="#34d399" stop-opacity="0.6"/>
                <stop offset="85%" stop-color="#818cf8" stop-opacity="0.6"/>
                <stop offset="100%" stop-color="#22d3ee" stop-opacity="0.6"/>
              </linearGradient>
              <marker id="spec-arr-r" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 8 3, 0 6" fill="rgba(255,255,255,0.3)"/>
              </marker>
            </defs>
            <!-- Labels top -->
            <text x="20" y="18" fill="rgba(248,113,113,0.7)" font-size="11" font-weight="600" font-family="system-ui">Lightest</text>
            <text x="820" y="18" fill="rgba(34,211,238,0.7)" font-size="11" font-weight="600" font-family="system-ui" text-anchor="end">Strongest</text>
            <!-- Arrow -->
            <line x1="20" y1="30" x2="860" y2="30" stroke="url(#spectrum-grad)" stroke-width="3" marker-end="url(#spec-arr-r)"/>
            <!-- Nodes -->
            <!-- L1: Process -->
            <circle cx="60" cy="30" r="6" fill="#f87171"/>
            <text x="60" y="62" fill="#f87171" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">🔓 Process</text>
            <text x="60" y="76" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">seccomp</text>
            <text x="60" y="88" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">Landlock</text>
            <text x="60" y="108" fill="rgba(248,113,113,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">Near-zero</text>
            <text x="60" y="118" fill="rgba(248,113,113,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">overhead</text>
            <!-- L2: Namespace -->
            <circle cx="210" cy="30" r="6" fill="#fb923c"/>
            <text x="210" y="62" fill="#fb923c" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">🧱 Namespace</text>
            <text x="210" y="76" fill="rgba(251,146,60,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">bubblewrap</text>
            <text x="210" y="88" fill="rgba(251,146,60,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">Firejail</text>
            <text x="210" y="108" fill="rgba(251,146,60,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">Near-zero</text>
            <text x="210" y="118" fill="rgba(251,146,60,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">overhead</text>
            <!-- L3: Container -->
            <circle cx="380" cy="30" r="6" fill="#fbbf24"/>
            <text x="380" y="62" fill="#fbbf24" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">📦 Container</text>
            <text x="380" y="76" fill="rgba(251,191,36,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">Docker</text>
            <text x="380" y="88" fill="rgba(251,191,36,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">Podman · Incus</text>
            <text x="380" y="108" fill="rgba(251,191,36,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">Low</text>
            <text x="380" y="118" fill="rgba(251,191,36,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">overhead</text>
            <!-- L4/L5: MicroVM -->
            <circle cx="580" cy="30" r="6" fill="#818cf8"/>
            <text x="580" y="62" fill="#818cf8" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">🖥️ MicroVM</text>
            <text x="580" y="76" fill="rgba(129,140,248,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">Firecracker</text>
            <text x="580" y="88" fill="rgba(129,140,248,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">E2B · Cloud Hypervisor</text>
            <text x="580" y="108" fill="rgba(129,140,248,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">Medium-High</text>
            <text x="580" y="118" fill="rgba(129,140,248,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">overhead</text>
            <!-- L7: Policy Engine -->
            <circle cx="800" cy="30" r="6" fill="#22d3ee"/>
            <text x="800" y="62" fill="#22d3ee" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">🛡️ Policy Engine</text>
            <text x="800" y="76" fill="rgba(34,211,238,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">OpenShell</text>
            <text x="800" y="88" fill="rgba(34,211,238,0.6)" text-anchor="middle" font-size="9" font-family="system-ui">OPA + Landlock</text>
            <text x="800" y="108" fill="rgba(34,211,238,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">Medium</text>
            <text x="800" y="118" fill="rgba(34,211,238,0.5)" text-anchor="middle" font-size="8" font-family="system-ui">overhead</text>
            <!-- vertical tick lines -->
            <line x1="60" y1="36" x2="60" y2="54" stroke="#f87171" stroke-width="1" opacity="0.4"/>
            <line x1="210" y1="36" x2="210" y2="54" stroke="#fb923c" stroke-width="1" opacity="0.4"/>
            <line x1="380" y1="36" x2="380" y2="54" stroke="#fbbf24" stroke-width="1" opacity="0.4"/>
            <line x1="580" y1="36" x2="580" y2="54" stroke="#818cf8" stroke-width="1" opacity="0.4"/>
            <line x1="800" y1="36" x2="800" y2="54" stroke="#22d3ee" stroke-width="1" opacity="0.4"/>
            <!-- Level labels at bottom -->
            <text x="60" y="145" fill="rgba(248,113,113,0.4)" text-anchor="middle" font-size="9" font-family="system-ui">L1</text>
            <text x="210" y="145" fill="rgba(251,146,60,0.4)" text-anchor="middle" font-size="9" font-family="system-ui">L2</text>
            <text x="380" y="145" fill="rgba(251,191,36,0.4)" text-anchor="middle" font-size="9" font-family="system-ui">L3–L4</text>
            <text x="580" y="145" fill="rgba(129,140,248,0.4)" text-anchor="middle" font-size="9" font-family="system-ui">L5</text>
            <text x="800" y="145" fill="rgba(34,211,238,0.4)" text-anchor="middle" font-size="9" font-family="system-ui">L7</text>
          </svg>
        </div>

        <!-- 3 framing cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="framing-card group bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 transition-all hover:border-accent-rose/30 hover:bg-white/[0.05]">
