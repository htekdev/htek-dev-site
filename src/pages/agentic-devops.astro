---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const beliefs = [
  {
    icon: '🛡️',
    title: 'Set the Rules Before You Hit Go',
    description: 'Agents move fast. Guardrails need to exist before they start — not after something breaks.',
  },
  {
    icon: '🧪',
    title: 'No Tests, No Ship',
    description: 'If the agent can\'t prove its work with passing tests, it doesn\'t get committed. That\'s the line.',
  },
  {
    icon: '🏗️',
    title: 'Make Bad Changes Impossible',
    description: 'Don\'t rely on agents following instructions. Build structural boundaries they literally can\'t cross.',
  },
  {
    icon: '💡',
    title: 'Empower the Developer, Not Just the Throughput',
    description: 'More PRs per hour means nothing if developers feel like babysitters. The goal is creative control.',
  },
  {
    icon: '🔄',
    title: 'Detect and Fix Before Anyone Notices',
    description: 'The real promise isn\'t autonomous deployment — it\'s autonomous detection and resolution of problems.',
  },
];

const tools = [
  {
    name: 'GitHub Copilot',
    category: 'Agent Runtime',
    description: 'AI pair programming that evolved into a full agent runtime. Copilot isn\'t just autocomplete — it\'s the foundation for coding agents that understand your entire codebase.',
    link: 'https://github.com/features/copilot',
  },
  {
    name: 'Agentic Workflows',
    category: 'CI/CD Orchestration',
    description: 'GitHub Actions meets AI. Write CI/CD in Markdown, define safe-outputs, and let agents orchestrate multi-step pipelines with built-in governance.',
    link: '/articles/github-agentic-workflows-hands-on-guide',
  },
  {
    name: 'Copilot SDK',
    category: 'Agent Development',
    description: 'Production-grade SDK for building custom agents. Model routing, tool orchestration, and enterprise-ready authentication — not a toy wrapper.',
    link: '/articles/github-copilot-sdk-agents-for-every-app',
  },
  {
    name: 'Agent Hooks & Hookflows',
    category: 'Governance',
    description: 'Pre-commit and pre-push enforcement for agent behavior. Hooks validate architecture rules, mock policies, and test coverage before code ever leaves the IDE.',
    link: '/articles/agent-hooks-controlling-ai-codebase',
  },
  {
    name: 'Model Context Protocol',
    category: 'Infrastructure Access',
    description: 'MCP gives agents structured access to your infrastructure — Azure resources, databases, APIs — through a standardized protocol with built-in security boundaries.',
    link: 'https://modelcontextprotocol.io',
  },
  {
    name: 'Self-Healing Infrastructure',
    category: 'Autonomous Operations',
    description: 'Agents that monitor, detect anomalies, and execute remediation autonomously. From log analysis to scaling decisions — with human approval gates where it matters.',
    link: '/articles/self-healing-infrastructure-with-agentic-ai',
  },
];

const articles = [
  {
    title: 'Agentic DevOps: The Next Evolution of Shift Left',
    description: 'DevOps protected teams from velocity. Agentic AI creates velocity so extreme we need DevOps designed for agents, not humans.',
    slug: 'agentic-devops-next-evolution-of-shift-left',
  },
  {
    title: 'Agentic-Ops: A Workflow Framework for AI Agents',
    description: 'Stop blaming AI for messy code. The problem isn\'t agent velocity — it\'s that you haven\'t built the guardrails to match it.',
    slug: 'agentic-ops-workflow-framework-for-ai-agents',
  },
  {
    title: 'Building Agent-Proof Architecture',
    description: 'Layered enforcement that makes agents structurally incapable of shipping untested code.',
    slug: 'agent-proof-architecture-agentic-devops',
  },
  {
    title: 'Tests Are Everything in Agentic AI',
    description: 'Without comprehensive test coverage, agentic AI will fail. Here\'s how to build DevOps guardrails that prevent AI from shipping broken code.',
    slug: 'tests-are-everything-agentic-ai',
  },
  {
    title: 'Test Enforcement Architecture for AI Agents',
    description: 'I built test coverage enforcement that blocks AI agents from shipping untested code.',
    slug: 'test-enforcement-architecture-ai-agents',
  },
  {
    title: 'Self-Healing Infrastructure with Agentic AI',
    description: 'How GitHub Copilot and Claude Code with Azure MCP server are enabling self-healing DevOps environments.',
    slug: 'self-healing-infrastructure-with-agentic-ai',
  },
  {
    title: 'Agent Harnesses: Controlling AI Agents in 2026',
    description: 'Enterprises average 12 AI agents with only 27% connected. The real challenge isn\'t building agents — it\'s the harness that governs them.',
    slug: 'agent-harnesses-controlling-ai-agents-2026',
  },
  {
    title: 'Agent Hooks: Controlling AI in Your Codebase',
    description: 'Instructions alone aren\'t enforcement. Here\'s how I built a hook-based system to make AI agents respect architecture rules.',
    slug: 'agent-hooks-controlling-ai-codebase',
  },
  {
    title: 'GitHub Agentic Workflows: A Hands-On Guide',
    description: 'I wrote GitHub automation in Markdown instead of YAML. Here\'s what I learned building 4 AI-powered workflows in 30 minutes.',
    slug: 'github-agentic-workflows-hands-on-guide',
  },
  {
    title: 'How Agentic AI Is Transforming Dev Teams',
    description: 'Development used to be the bottleneck. Now features are easy. The new constraint? Figuring out what to build.',
    slug: 'agentic-ai-transforming-dev-teams',
  },
];
---

<BaseLayout
  title="Agentic DevOps — htek.dev"
  description="DevOps was built for humans. Agents need something new. Explore the philosophy, tooling, and architecture behind Agentic DevOps."
>
  <Navbar />
  <main id="main-content">

    <!-- Hero -->
    <section class="relative min-h-[85vh] flex items-center bg-bg-void overflow-hidden">
      <!-- Background effects -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-accent-green/8 rounded-full blur-[120px]"></div>
        <div class="absolute top-1/3 left-1/4 w-[300px] h-[300px] bg-accent-cyan/5 rounded-full blur-[80px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[250px] h-[250px] bg-accent-rose/5 rounded-full blur-[80px]"></div>
      </div>
      <!-- Grid overlay -->
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(52,211,153,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(52,211,153,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-5xl mx-auto px-6 pt-32 pb-20 text-center">
        <span class="inline-block font-mono text-accent-green text-sm tracking-wider mb-6 opacity-80">// agentic-devops</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-text-primary mb-8 leading-tight">
          DevOps Was Built for
          <span class="block mt-2">
            <span class="agentic-gradient">Humans.</span>
          </span>
          <span class="block text-3xl md:text-5xl lg:text-5xl mt-4 text-text-secondary font-medium">
            Agents Need Something New.
          </span>
        </h1>
        <p class="text-lg md:text-xl text-text-secondary max-w-3xl mx-auto mb-12 leading-relaxed">
          Shift-left was about moving quality earlier. Agentic DevOps is about
          designing systems where AI agents operate at machine speed — with
          governance, test enforcement, and architecture boundaries that make
          safety structural, not aspirational.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#evolution" class="inline-flex items-center gap-2 bg-accent-green/15 border border-accent-green/30 text-accent-green font-semibold px-8 py-3 rounded-lg hover:bg-accent-green/25 transition-all">
            See the Evolution
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
          </a>
          <a href="#beliefs" class="inline-flex items-center gap-2 text-text-muted hover:text-text-primary font-medium px-8 py-3 rounded-lg transition-colors">
            Core Beliefs →
          </a>
          <a href="#tooling" class="inline-flex items-center gap-2 text-text-muted hover:text-text-primary font-medium px-8 py-3 rounded-lg transition-colors">
            Explore the Stack →
          </a>
        </div>
      </div>
    </section>

    <!-- The Evolution -->
    <section id="evolution" class="fade-in py-24 md:py-32 bg-bg-surface relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/3 w-[400px] h-[400px] bg-accent-green/5 rounded-full blur-[100px]"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-6">
        <span class="inline-block font-mono text-accent-green text-sm tracking-wider mb-4">// evolution</span>
        <h2 class="text-3xl md:text-5xl font-heading font-bold text-text-primary mb-6">
          How We Got Here
        </h2>
        <p class="text-text-secondary text-lg max-w-3xl mb-16">
          Every era of software delivery follows the same pattern: compress the feedback loop.
          The tighter the loop, the faster you learn, the lower the risk, the more you ship.
        </p>

        <!-- Era Cards -->
        <div class="space-y-12">

          <!-- Era 1: The Old Way -->
          <div class="era-card bg-white/[0.02] border border-white/[0.06] rounded-2xl p-8 md:p-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-block font-mono text-[10px] text-red-400 tracking-widest uppercase bg-red-400/10 border border-red-400/20 rounded-full px-3 py-1">Phase 1</span>
              <h3 class="text-xl md:text-2xl font-heading font-semibold text-text-primary">The Linear Pipeline</h3>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed max-w-2xl mb-8">
              Before DevOps, teams planned for months, built in isolation, tested at the end, and deployed infrequently.
              Feedback arrived after the fact — and the cost of fixing issues grew the further right they were discovered.
            </p>
            <div class="overflow-x-auto">
              <svg viewBox="0 0 800 130" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[800px] mx-auto">
                <defs>
                  <marker id="evo-arr-r" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                    <polygon points="0 0, 8 3, 0 6" fill="#f87171"/>
                  </marker>
                </defs>
                <rect x="10" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"/>
                <text x="75" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Plan</text>
                <text x="75" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">2-3 months</text>
                <rect x="170" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"/>
                <text x="235" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Develop</text>
                <text x="235" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">3-6 months</text>
                <rect x="330" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"/>
                <text x="395" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Test</text>
                <text x="395" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">1-2 months</text>
                <rect x="490" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"/>
                <text x="555" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Deploy</text>
                <text x="555" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">1-2 weeks</text>
                <rect x="650" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"/>
                <text x="715" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Feedback</text>
                <text x="715" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">Too late</text>
                <line x1="140" y1="54" x2="168" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"/>
                <line x1="300" y1="54" x2="328" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"/>
                <line x1="460" y1="54" x2="488" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"/>
                <line x1="620" y1="54" x2="648" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"/>
                <line x1="10" y1="100" x2="780" y2="100" stroke="rgba(248,113,113,0.2)" stroke-width="1" stroke-dasharray="4"/>
                <text x="395" y="120" fill="#f87171" text-anchor="middle" font-size="12" font-weight="600" font-family="system-ui">6-12 months per release</text>
              </svg>
            </div>
          </div>

          <!-- Era 2: DevOps -->
          <div class="era-card bg-white/[0.02] border border-white/[0.06] rounded-2xl p-8 md:p-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-block font-mono text-[10px] text-blue-400 tracking-widest uppercase bg-blue-400/10 border border-blue-400/20 rounded-full px-3 py-1">Phase 2</span>
              <h3 class="text-xl md:text-2xl font-heading font-semibold text-text-primary">The Continuous Loop</h3>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed max-w-2xl mb-8">
              DevOps turned the line into a loop. Test quicker, deliver quicker, run security checks quicker, plan quicker.
              Everything shifted left. Feedback became continuous.
            </p>
            <div class="overflow-x-auto">
              <svg viewBox="0 0 700 310" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[700px] mx-auto">
                <defs>
                  <marker id="evo-arr-b" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                    <polygon points="0 0, 8 3, 0 6" fill="#60a5fa"/>
                  </marker>
                </defs>
                <ellipse cx="350" cy="140" rx="195" ry="105" fill="none" stroke="rgba(96,165,250,0.12)" stroke-width="1.5"/>
                <g transform="translate(350,140)">
                  <g transform="translate(0,-105)">
                    <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Plan</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">1-2 weeks</text>
                  </g>
                  <g transform="translate(138,-74)">
                    <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Code</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">days</text>
                  </g>
                  <g transform="translate(170,0)">
                    <rect x="-50" y="-16" width="100" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Build & Test</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">minutes (CI)</text>
                  </g>
                  <g transform="translate(138,74)">
                    <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Release</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">hours (CD)</text>
                  </g>
                  <g transform="translate(0,105)">
                    <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Deploy</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">minutes</text>
                  </g>
                  <g transform="translate(-138,74)">
                    <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Operate</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">continuous</text>
                  </g>
                  <g transform="translate(-170,0)">
                    <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Monitor</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">real-time</text>
                  </g>
                  <g transform="translate(-138,-74)">
                    <rect x="-46" y="-16" width="92" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"/>
                    <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Feedback</text>
                    <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">immediate</text>
                  </g>
                  <!-- Clockwise arrows -->
                  <path d="M 38,-103 Q 98,-98 126,-82" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M 172,-55 Q 188,-30 178,-8" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M 178,12 Q 188,35 172,58" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M 126,86 Q 98,103 38,105" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M -38,105 Q -98,103 -126,86" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M -172,58 Q -188,35 -178,12" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M -178,-8 Q -188,-30 -172,-55" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <path d="M -126,-82 Q -98,-98 -38,-103" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"/>
                  <text x="0" y="-4" fill="rgba(96,165,250,0.4)" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">CONTINUOUS</text>
                  <text x="0" y="10" fill="rgba(96,165,250,0.4)" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">LOOP</text>
                </g>
                <text x="350" y="290" fill="#60a5fa" text-anchor="middle" font-size="12" font-weight="600" font-family="system-ui">Days to weeks per change — feedback is continuous</text>
              </svg>
            </div>
          </div>

          <!-- Era 3: Agentic DevOps -->
          <div class="era-card bg-white/[0.02] border border-accent-green/10 rounded-2xl p-8 md:p-10 relative">
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent-green/[0.03] to-transparent pointer-events-none"></div>
            <div class="relative">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-block font-mono text-[10px] text-accent-green tracking-widest uppercase bg-accent-green/10 border border-accent-green/20 rounded-full px-3 py-1">Phase 3</span>
                <h3 class="text-xl md:text-2xl font-heading font-semibold text-text-primary">The Collapsed Loop</h3>
              </div>
              <p class="text-text-secondary text-sm leading-relaxed max-w-2xl mb-3">
                What a high-performing developer does in <strong class="text-text-primary">6 hours</strong>, an agentic workflow does in <strong class="text-accent-green">30 minutes</strong>.
                The DevOps loop collapses into a tight core. Ideas flow in, tested artifacts flow out.
              </p>
              <p class="text-text-secondary text-sm leading-relaxed max-w-2xl mb-8">
                Testing, security, and validation happen <em>inside</em> the agent's loop — not as separate stages.
              </p>
              <div class="overflow-x-auto">
                <svg viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[800px] mx-auto">
                  <defs>
                    <marker id="evo-arr-gn" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                      <polygon points="0 0, 8 3, 0 6" fill="#34d399"/>
                    </marker>
                    <marker id="evo-arr-y" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                      <polygon points="0 0, 8 3, 0 6" fill="#fbbf24"/>
                    </marker>
                    <marker id="evo-arr-em" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                      <polygon points="0 0, 8 3, 0 6" fill="#6ee7b7"/>
                    </marker>
                    <radialGradient id="evo-cg" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#34d399" stop-opacity="0.1"/>
                      <stop offset="100%" stop-color="#34d399" stop-opacity="0"/>
                    </radialGradient>
                  </defs>
                  <!-- Ideas -->
                  <text x="75" y="55" fill="#fbbf24" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui">💡 IDEAS</text>
                  <rect x="15" y="68" width="120" height="26" rx="6" fill="rgba(251,191,36,0.06)" stroke="rgba(251,191,36,0.3)" stroke-width="1"/>
                  <text x="75" y="86" fill="#fbbf24" text-anchor="middle" font-size="10" font-family="system-ui">"Refactor auth"</text>
