---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter(a => !a.data.draft)
    .map((article) => ({
      params: { slug: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const wordCount = article.body ? article.body.split(/\s+/).filter(Boolean).length : undefined;
const readingTime = wordCount ? `${Math.ceil(wordCount / 250)} min read` : undefined;
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  pubDate={article.data.pubDate}
  updatedDate={article.data.updatedDate}
  tags={article.data.tags}
  heroImage={article.data.heroImage}
  readingTime={readingTime}
  wordCount={wordCount}
  slug={article.id}
>
  <Content />
</ArticleLayout>
