---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface PageSite {
  name: string;
  url: string;
  repo: string;
  description: string;
  tech: string;
  status: 'live' | 'coming-soon';
  category: 'copilot' | 'project' | 'demo';
  icon: string;
  highlights: string[];
  autoMaintained: boolean;
}

const sites: PageSite[] = [
  {
    name: 'GitHub Copilot CLI Reference',
    url: 'https://htekdev.github.io/copilot-cli-reference/',
    repo: 'https://github.com/htekdev/copilot-cli-reference',
    description: 'Single-page reference guide for GitHub Copilot CLI — ecosystem overview, configuration, customization, and usage. Built for live demos and quick lookups.',
    tech: 'Static HTML · GitHub Pages',
    status: 'live',
    category: 'copilot',
    icon: '⌨️',
    highlights: [
      'Complete CLI ecosystem map',
      'Configuration & customization reference',
      'Learning paths for onboarding',
      'Release velocity tracker',
      'Weekly auto-updated content',
    ],
    autoMaintained: true,
  },
  {
    name: 'Copilot for Visual Studio Guide',
    url: 'https://htekdev.github.io/copilot-visual-studio-guide/',
    repo: 'https://github.com/htekdev/copilot-visual-studio-guide',
    description: 'Curated resource hub for GitHub Copilot in Visual Studio — changelog tracking, 30+ video library organized by enablement pillar, and official resource links.',
    tech: 'Astro · GitHub Pages',
    status: 'live',
    category: 'copilot',
    icon: '🟣',
    highlights: [
      '30+ curated videos by pillar',
      'What\'s New changelog tracker',
      'Official resource aggregation',
      'Presentation-ready materials',
      'Copilot SWE agent workflow powered',
    ],
    autoMaintained: true,
  },
  {
    name: 'Home OS — Landing & Docs',
    url: 'https://htekdev.github.io/home-os-site/',
    repo: 'https://github.com/htekdev/home-os-site',
    description: 'Landing page and documentation for Home OS — the autonomous AI home assistant framework powered by GitHub Copilot CLI and Telegram.',
    tech: 'Static HTML · GitHub Pages',
    status: 'live',
    category: 'project',
    icon: '🏠',
    highlights: [
      '8 agent system overview',
      '7 extension catalog',
      '4-tier memory architecture docs',
      'Go-to-market and pricing tiers',
      'Quick-start guide',
    ],
    autoMaintained: false,
  },
  {
    name: 'htek.dev',
    url: 'https://htek.dev',
    repo: 'https://github.com/htekdev/htek-dev-site',
    description: 'Personal site and technical blog — articles on AI agents, DevOps, GitHub Copilot, and software architecture. Syndicated to DEV.to, Hashnode, and Medium.',
    tech: 'Astro · React · MDX · Tailwind · Netlify',
    status: 'live',
    category: 'project',
    icon: '🌐',
    highlights: [
      '15+ technical articles',
      'Auto-syndication pipeline',
      'YouTube video library (205+ videos)',
      'Consulting & booking integration',
      'Weekly content updates via Copilot SWE',
    ],
    autoMaintained: true,
  },
  {
    name: 'Agentic DevOps Deep Dive',
    url: 'https://htek.dev/agentic-devops',
    repo: 'https://github.com/htekdev/htek-dev-site',
    description: 'Comprehensive reference page on Agentic DevOps — the paradigm shift from human-speed to machine-speed development with AI agent governance.',
    tech: 'Astro page on htek.dev',
    status: 'live',
    category: 'copilot',
    icon: '🤖',
    highlights: [
      'Full agentic DevOps framework',
      'Agent governance patterns',
      'Hookflow enforcement layers',
      'Presentation deck included',
    ],
    autoMaintained: false,
  },
];

const categories = {
  copilot: { label: 'GitHub Copilot', color: 'accent-cyan' },
  project: { label: 'Projects & Portfolio', color: 'accent-green' },
  demo: { label: 'Demos & Labs', color: 'accent-rose' },
};

const categoryOrder: Array<keyof typeof categories> = ['copilot', 'project', 'demo'];
const groupedSites = categoryOrder
  .map(cat => ({
    key: cat,
    ...categories[cat],
    sites: sites.filter(s => s.category === cat),
  }))
  .filter(g => g.sites.length > 0);
---

<BaseLayout
  title="GitHub Pages Index — All Reference Sites by htekdev"
  description="Directory of GitHub Pages sites maintained by Hector Flores (htekdev) — Copilot CLI reference, Visual Studio guide, Home OS docs, and more. Auto-maintained with GitHub Copilot."
>
  <Navbar />
  <main id="main-content">

    <!-- Hero -->
    <section class="relative min-h-[70vh] flex items-center bg-bg-void overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-accent-cyan/8 rounded-full blur-[120px]"></div>
        <div class="absolute top-1/3 left-1/4 w-[300px] h-[300px] bg-accent-green/5 rounded-full blur-[80px]"></div>
      </div>
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(88,166,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(88,166,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-5xl mx-auto px-6 pt-32 pb-20 text-center">
        <span class="inline-block font-mono text-accent-cyan text-sm tracking-wider mb-6 opacity-80">// github-pages</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-text-primary mb-8 leading-tight">
          Reference Sites
          <span class="block mt-2 pages-gradient">Auto-Maintained by Copilot</span>
        </h1>
        <p class="text-lg md:text-xl text-text-secondary max-w-3xl mx-auto mb-8 leading-relaxed">
          I build curated reference pages for the tools and technologies I work with — then let GitHub Copilot keep them current.
          Each site is purpose-built for demos, onboarding, and quick lookups.
        </p>
        <div class="flex items-center justify-center gap-8 text-sm text-text-muted">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent-green animate-pulse"></span>
            <span>{sites.filter(s => s.status === 'live').length} live sites</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-accent-cyan">⚡</span>
            <span>{sites.filter(s => s.autoMaintained).length} auto-maintained</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Sites by Category -->
    {groupedSites.map(group => (
      <section class="fade-in py-20 md:py-28 even:bg-bg-surface odd:bg-bg-void relative overflow-hidden">
        <div class="max-w-6xl mx-auto px-6">
          <span class={`inline-block font-mono text-${group.color} text-sm tracking-wider mb-4`}>// {group.key}</span>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-text-primary mb-12">{group.label}</h2>

          <div class="space-y-8">
            {group.sites.map(site => (
              <div class="group bg-white/[0.02] border border-white/[0.06] backdrop-blur-sm rounded-2xl p-8 transition-all duration-300 hover:border-accent-cyan/20 hover:-translate-y-0.5">
                <div class="flex flex-col lg:flex-row lg:items-start gap-6">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-2xl">{site.icon}</span>
                      <h3 class="text-xl font-heading font-semibold text-text-primary group-hover:text-accent-cyan transition-colors">
                        {site.name}
                      </h3>
                      {site.autoMaintained && (
                        <span class="inline-flex items-center gap-1 text-xs font-mono bg-accent-green/10 text-accent-green border border-accent-green/20 px-2 py-0.5 rounded-full">
                          ⚡ auto-maintained
                        </span>
                      )}
                      {site.status === 'live' && (
                        <span class="w-2 h-2 rounded-full bg-accent-green animate-pulse" title="Live"></span>
                      )}
                    </div>
                    <p class="text-text-secondary text-sm leading-relaxed mb-4">{site.description}</p>
                    <div class="flex flex-wrap gap-2 mb-4">
                      {site.highlights.map(h => (
                        <span class="text-xs bg-white/[0.04] border border-white/[0.08] text-text-muted px-2.5 py-1 rounded-md">
                          {h}
                        </span>
                      ))}
                    </div>
                    <p class="text-xs text-text-muted/60 font-mono">{site.tech}</p>
                  </div>
                  <div class="flex flex-col gap-2 lg:items-end shrink-0">
                    <a
                      href={site.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 bg-accent-cyan/10 border border-accent-cyan/20 text-accent-cyan font-medium text-sm px-5 py-2.5 rounded-lg hover:bg-accent-cyan/20 transition-all"
                    >
                      Visit Site
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                    <a
                      href={site.repo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-text-muted hover:text-text-primary text-sm px-5 py-2 rounded-lg transition-colors"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                      View Source
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- How It Works -->
    <section class="fade-in py-24 md:py-32 bg-bg-void relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent-cyan/5 rounded-full blur-[100px]"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-6">
        <span class="inline-block font-mono text-accent-cyan text-sm tracking-wider mb-4">// how it works</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-text-primary mb-6">Auto-Maintained by Copilot</h2>
        <p class="text-text-secondary text-lg max-w-3xl mb-12">
          Most of these sites are automatically updated by GitHub Copilot's SWE agent. A weekly cron triggers a workflow that researches changes, updates content, and opens a PR — no manual intervention needed.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl p-6">
            <span class="text-2xl mb-3 block">📅</span>
            <h3 class="font-heading font-semibold text-text-primary mb-2">Weekly Cron</h3>
            <p class="text-text-muted text-sm">A GitHub Actions schedule triggers Copilot's SWE agent to check for updates every week.</p>
          </div>
          <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl p-6">
            <span class="text-2xl mb-3 block">🔍</span>
            <h3 class="font-heading font-semibold text-text-primary mb-2">Research & Update</h3>
            <p class="text-text-muted text-sm">The agent crawls official docs, changelogs, and release notes to find what's changed since the last update.</p>
          </div>
          <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl p-6">
            <span class="text-2xl mb-3 block">🔄</span>
            <h3 class="font-heading font-semibold text-text-primary mb-2">PR & Deploy</h3>
            <p class="text-text-muted text-sm">Changes are committed to a branch, a PR is opened for review, and merging auto-deploys to GitHub Pages.</p>
          </div>
        </div>
        <div class="mt-10 text-center">
          <a
            href="/articles/auto-maintaining-reference-pages-copilot-cli"
            class="inline-flex items-center gap-2 text-accent-cyan font-medium hover:underline transition-colors"
          >
            Read the full article on this workflow →
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .pages-gradient {
    background: linear-gradient(135deg, #58a6ff, #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
